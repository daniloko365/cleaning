# Public canonical origin used at build time.
NEXT_PUBLIC_SITE_URL=https://novacleanoc.com

# Cloudflare deployment resource names/IDs (never commit real secrets).
CLOUDFLARE_WORKER_NAME=novaclean-oc
CLOUDFLARE_D1_DATABASE_NAME=novaclean-production
CLOUDFLARE_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000
CLOUDFLARE_R2_BUCKET_NAME=novaclean-media

# Set with `wrangler secret put`, not in a committed env file.
ADMIN_ACCESS_TOKEN=
